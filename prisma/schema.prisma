generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Unspsc {
  id         Int    @id @default(autoincrement())
  code       String @unique
  name       String
  level      Int
  level_name String // segment/family/class/commodity
}

model MaterialCategory {
  id                String   @id
  material_category String
  status            String?
  attributes        Json?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
}
